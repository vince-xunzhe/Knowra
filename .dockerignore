.git
.DS_Store

# Local runtimes and build output
**/__pycache__
**/*.pyc
backend/.venv
frontend/node_modules
frontend/dist
frontend/*.tsbuildinfo

# Local user data is mounted at runtime instead of baked into images.
data/*
!data/artifacts/
!data/artifacts/.gitkeep
!data/papers/
!data/papers/.gitkeep

# Logs and local env files
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.env
.env.*
!.env.example
