# Copy this file to .env for machine-local settings.

# Required for paper processing. You can also set this in the app settings page.
OPENAI_API_KEY=

# auto uses Docker Compose when available, then falls back to native mode.
# Valid values: auto, docker, native
KNOWLEDGE_WIKI_MODE=auto

# Leave empty to let start.sh find free ports automatically.
BACKEND_PORT=
FRONTEND_PORT=

# Set to 0 on servers or SSH sessions.
OPEN_BROWSER=1

# Docker file watcher fallback for environments where native file events do not work.
CHOKIDAR_USEPOLLING=false
