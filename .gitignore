.DS_Store
*.swp
*.swo
.idea/
.vscode/
.claude/

# Environment and secrets
.env
.env.*
!.env.example
data/config.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
backend/.venv/

